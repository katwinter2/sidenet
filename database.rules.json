{
  "rules": {
    "worlds": {
      ".read": true,
      "$worldId": {
        ".write": "auth !== null && (data.child('authorUid').val() === auth.uid || !data.exists())",
        "entries": {
          ".indexOn": ["type", "createdAt", "name"]
        }
      }
    },
    "users": {
      "$uid": {
        ".read": "auth !== null && auth.uid === $uid",
        ".write": "auth !== null && auth.uid === $uid"
      }
    },
    "feed": {
      ".read": true,
      ".write": true,
      ".indexOn": ["timestamp", "url"]
    },
    "explorations": {
      ".read": true,
      ".write": true
    }
  }
}
